#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

API_STARTED_BY_SCRIPT=0
VITE_STARTED_BY_SCRIPT=0
VITE_PID=""
USE_DEV_MODE=1

# Prefer nvm-managed Node in non-interactive shells when available.
if [[ -s "$HOME/.nvm/nvm.sh" ]]; then
  # shellcheck disable=SC1090
  source "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
fi

NODE_MAJOR="$(node -p "process.versions.node.split('.')[0]" 2>/dev/null || echo 0)"
if [[ "$NODE_MAJOR" -lt 20 ]]; then
  USE_DEV_MODE=0
  echo "Node.js $NODE_MAJOR detected; using release-mode UI fallback (no Vite dev server)."
fi

if curl -sf http://127.0.0.1:8765/health >/dev/null 2>&1; then
  echo "Chatbot API already running on :8765"
else
  echo "Starting chatbot API..."
  bash chatbot/api/startup.sh
  API_STARTED_BY_SCRIPT=1
  # Give uvicorn time to boot and load artifacts.
  for _ in $(seq 1 20); do
    if curl -sf http://127.0.0.1:8765/health >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
  curl -sf http://127.0.0.1:8765/health >/dev/null
  echo "Chatbot API ready on :8765"
fi

if [[ "$USE_DEV_MODE" -eq 1 ]]; then
  if curl -sf http://127.0.0.1:1420 >/dev/null 2>&1; then
    echo "UI dev server already running on :1420"
  else
    echo "Starting UI dev server on :1420..."
    mkdir -p logs
    (
      cd ui
      npm run dev -- --host 127.0.0.1 --port 1420 > "$ROOT_DIR/logs/ui_dev.log" 2>&1
    ) &
    VITE_PID=$!
    VITE_STARTED_BY_SCRIPT=1

    for _ in $(seq 1 40); do
      if curl -sf http://127.0.0.1:1420 >/dev/null 2>&1; then
        break
      fi
      sleep 1
    done

    if ! curl -sf http://127.0.0.1:1420 >/dev/null 2>&1; then
      echo "UI dev server failed to start. Falling back to release-mode UI."
      tail -n 20 "$ROOT_DIR/logs/ui_dev.log" || true
      USE_DEV_MODE=0
    else
      echo "UI dev server ready on :1420"
    fi
  fi
fi

if [[ "$USE_DEV_MODE" -eq 1 ]]; then
  echo "Launching native UI (dev mode)..."
  cargo run -p ui
else
  if [[ ! -f "$ROOT_DIR/ui/dist/index.html" ]]; then
    echo "Missing ui/dist/index.html for release-mode fallback."
    echo "Please build frontend once with a modern Node.js: cd ui && npm run build"
    exit 1
  fi
  echo "Launching native UI (release-mode frontendDist fallback)..."
  cargo run -p ui --release
fi

if [[ "$VITE_STARTED_BY_SCRIPT" -eq 1 ]]; then
  echo "UI exited. Vite dev server remains running on :1420."
fi

if [[ "$API_STARTED_BY_SCRIPT" -eq 1 ]]; then
  echo "UI exited. Chatbot API is still running on :8765 (started by tauri-ui)."
fi