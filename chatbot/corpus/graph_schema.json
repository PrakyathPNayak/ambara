{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AmbaraSerializedGraph",
    "type": "object",
    "required": [
        "nodes",
        "connections",
        "metadata"
    ],
    "properties": {
        "version": {
            "type": "string"
        },
        "metadata": {
            "type": "object"
        },
        "nodes": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "filter_id",
                    "position",
                    "parameters"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "filter_id": {
                        "type": "string"
                    },
                    "position": {
                        "type": "object",
                        "required": [
                            "x",
                            "y"
                        ],
                        "properties": {
                            "x": {
                                "type": "number"
                            },
                            "y": {
                                "type": "number"
                            }
                        },
                        "additionalProperties": false
                    },
                    "parameters": {
                        "type": "object"
                    },
                    "label": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "disabled": {
                        "type": "boolean"
                    }
                },
                "additionalProperties": true
            }
        },
        "connections": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "from_node",
                    "from_port",
                    "to_node",
                    "to_port"
                ],
                "properties": {
                    "from_node": {
                        "type": "string"
                    },
                    "from_port": {
                        "type": "string"
                    },
                    "to_node": {
                        "type": "string"
                    },
                    "to_port": {
                        "type": "string"
                    }
                },
                "additionalProperties": true
            }
        }
    },
    "additionalProperties": true
}