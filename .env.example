# Ambara environment configuration
# Copy this file to .env and fill in the values you need.

# ── LLM Backend ──────────────────────────────────────────────────────────────
# The chatbot auto-selects the first available backend in this priority order:
#   1. Anthropic  (if ANTHROPIC_API_KEY is set)
#   2. Groq       (if GROQ_API_KEY is set)
#   3. OpenAI     (if OPENAI_API_KEY is set)
#   4. Ollama     (local, default fallback)

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (fast inference — llama-3.3-70b-versatile default)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (local — used when no cloud key is set)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── ComfyUI ──────────────────────────────────────────────────────────────────
# URL of a running ComfyUI server (used by ComfyUI workflow nodes)
# COMFYUI_URL=http://127.0.0.1:8188
